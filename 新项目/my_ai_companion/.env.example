# =============================================================================
# AI 伴侣 - 环境配置文件
# =============================================================================
# 使用说明:
#   1. 复制此文件为 .env（不要直接修改 .env.example）
#   2. 填入你的 DeepSeek API Key
#   3. 根据需要调整其他配置项
# =============================================================================

# ---------------------------------------------------------------------------
# DeepSeek API 配置
# ---------------------------------------------------------------------------

# DeepSeek API Key（必填）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=your_api_key_here

# 对话模型（可选）
# - deepseek-v4-flash: 快速响应，推荐日常使用
# - deepseek-v4-pro: 高质量角色扮演，响应更精准
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding 模型（可选）
# 用于记忆系统的向量检索
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding-v2

# API 基础 URL（可选）
# 默认使用 DeepSeek 官方 API，也可指向兼容的代理服务
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------

# 日志级别: DEBUG, INFO, WARNING, ERROR
# 开发调试时建议使用 DEBUG，日常使用 INFO
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# 数据存储路径
# ---------------------------------------------------------------------------

# 数据存储目录（相对于项目根目录）
# 内存数据库、导出文件、用户设置等均存储在此目录下
DATA_DIR=./data