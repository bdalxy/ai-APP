# ============================================
# WeiXinAI 环境配置模板
# ============================================
# 使用说明：复制此文件为 .env 并填入实际配置
# 敏感信息（如 API Key）切勿提交到 GitHub！
# ============================================

# ------------------------------
# 基础配置（必填）
# ------------------------------

# AI 运行模式
# cloud: 使用云端 API（推荐）
# local: 使用本地模型
AI_MODE=cloud

# 消息平台
# wechat: 微信
# qq: QQ
PLATFORM=wechat

# ------------------------------
# 云端 API 配置（AI_MODE=cloud 时必填）
# ------------------------------

# DeepSeek API Key
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 模型名称
MODEL_NAME=deepseek-v4

# ------------------------------
# 本地模型配置（AI_MODE=local 时必填）
# ------------------------------

# 本地模型路径
LOCAL_MODEL_PATH=./models/your_model.gguf

# ------------------------------
# 记忆系统配置
# ------------------------------

# 记忆级别
# basic: 基础（100条记录）
# standard: 标准（500条记录）
# advanced: 高级（2000条记录）
MEMORY_LEVEL=standard

# ------------------------------
# 联网搜索配置（可选）
# ------------------------------

# 搜索提供商
# bing: 使用 Bing Search API
# duckduckgo: 使用 DuckDuckGo（无需 API Key）
SEARCH_PROVIDER=duckduckgo

# Bing Search API Key（使用 Bing 时必填）
# 从 https://www.microsoft.com/en-us/bing/apis/bing-web-search-api 获取
SEARCH_API_KEY=your_bing_api_key_here

# Bing Search 端点
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Google CSE ID（使用 Google 搜索时必填）
GOOGLE_CSE_ID=your_google_cse_id_here

# ------------------------------
# 日志配置
# ------------------------------

# 日志级别
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------
# API 服务配置
# ------------------------------

# 服务端口
API_PORT=8000

# 服务地址
API_HOST=0.0.0.0
