<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <!-- 通知权限（主动推送） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Android 14+ 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 录音权限（语音识别/语音消息） -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ─────────────────────────────────────────────────────────────
    品牌设备适配权限
    - REQUEST_IGNORE_BATTERY_OPTIMIZATIONS: 请求电池优化白名单
      （小米/华为/OPPO/vivo 后台保活必需）
    - RECEIVE_BOOT_COMPLETED: 开机自启动（重启后恢复定时器）
    - ACCESS_NOTIFICATION_POLICY: 通知使用权（部分厂商限制通知）
    - SYSTEM_ALERT_WINDOW: 悬浮窗权限（部分厂商通知弹窗需要）
    ───────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 前台服务类型：Android 14+ 需要声明 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- ─────────────────────────────────────────────────────────────
    屏幕适配：明确声明支持所有屏幕尺寸，避免 Google Play 过滤
    - smallScreens: 小屏手机（320dp 宽，如 3.5" 设备）
    - normalScreens: 标准手机（360dp-400dp 宽）
    - largeScreens: 小平板 / 大屏手机（600dp+ 宽）
    - xlargeScreens: 大平板 / 折叠屏展开态（720dp+ 宽）
    - anyDensity: 支持所有屏幕密度（mdpi ~ xxxhdpi）
    - 不设置 compatibleWidthLimitDp / largestWidthLimitDp，表示无宽度限制
    ───────────────────────────────────────────────────────────── -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true" />

    <application
        android:name=".AICompanionApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AICompanion"
        android:usesCleartextTraffic="false"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|density"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        android:resizeableActivity="true"
        android:foregroundServiceType="dataSync|specialUse"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MemoryManageActivity"
            android:exported="true"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".MemoryArchiveActivity"
            android:exported="true"
            android:label="记忆档案馆"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:label="设置"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".SettingsDetailActivity"
            android:exported="true"
            android:label="设置详情"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CharacterManageActivity"
            android:exported="true"
            android:label="角色管理"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CharacterSelectActivity"
            android:exported="true"
            android:label="选择角色"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CharacterActivity"
            android:exported="true"
            android:label="角色详情"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CharacterEditActivity"
            android:exported="true"
            android:label="编辑角色"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CharacterPreviewActivity"
            android:exported="true"
            android:label="角色预览"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".OnboardingActivity"
            android:exported="true"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".PluginManageActivity"
            android:exported="true"
            android:label="插件管理"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".WorldBookActivity"
            android:exported="true"
            android:label="世界书"
            android:theme="@style/Theme.AICompanion" />

        <activity
            android:name=".CrashLogViewerActivity"
            android:exported="true"
            android:label="崩溃日志"
            android:theme="@style/Theme.AICompanion" />

        <!-- FileProvider：用于分享导出的对话文件 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>