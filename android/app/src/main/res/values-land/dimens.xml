<?xml version="1.0" encoding="utf-8"?>
<!-- 尺寸资源文件：横屏适配 -->
<resources>
    <!-- ===== 顶栏 ===== -->
    <!-- 顶栏：横屏时降低高度，为内容留更多空间 -->
    <dimen name="topbar_height_land">48dp</dimen>

    <!-- ===== 内容最大宽度 ===== -->
    <!-- 横屏下设置/编辑类页面内容居中最大宽度 -->
    <dimen name="land_content_max_width">600dp</dimen>

    <!-- ===== 消息列表 ===== -->
    <!-- 横屏时增加水平内边距，使内容更集中 -->
    <dimen name="message_list_padding_land">16dp</dimen>

    <!-- 气泡最大宽度：横屏时更大，但不超出屏幕 -->
    <dimen name="message_bubble_max_width">360dp</dimen>

    <!-- ===== 列表页面 ===== -->
    <!-- 横屏时列表水平内边距 -->
    <dimen name="card_list_padding_horizontal">24dp</dimen>
    <!-- 横屏时列表垂直内边距 -->
    <dimen name="card_list_padding_vertical">10dp</dimen>

    <!-- ===== 间距 ===== -->
    <!-- 横屏时页面级间距适度增大 -->
    <dimen name="spacing_page">24dp</dimen>
    <dimen name="spacing_3xl">28dp</dimen>
    <dimen name="spacing_4xl">32dp</dimen>
    <dimen name="spacing_5xl">40dp</dimen>

    <!-- ===== 底部留白 ===== -->
    <dimen name="bottom_spacer">28dp</dimen>
    <dimen name="bottom_spacer_large">36dp</dimen>
</resources>