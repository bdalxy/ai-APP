<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ===== 主内容区域 ===== -->
    <FrameLayout
        android:id="@+id/main_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_gradient"
        android:clipToPadding="false">

        <com.aicompanion.app.ui.ParticleView
            android:id="@+id/particleView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/topbar_height"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_page"
                android:background="@drawable/bg_glass_top">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="@dimen/avatar_size_small"
                    android:layout_height="@dimen/avatar_size_small"
                    android:src="@drawable/ic_avatar_placeholder"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_character_select" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tv_default_character_name"
                        android:textSize="@dimen/text_title_small"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_online"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/accent_green" />
                </LinearLayout>

                <!-- 新对话按钮（图标按钮，更明显） -->
                <ImageButton
                    android:id="@+id/btnNewChat"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_new_chat"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/btn_new_chat"
                    android:tint="@color/text_primary"
                    android:scaleType="centerInside"
                    android:padding="6dp" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:src="@drawable/ic_search"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_settings"
                    android:tint="@color/text_primary"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 搜索栏 -->
            <LinearLayout
                android:id="@+id/layoutSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_page"
                android:paddingVertical="@dimen/search_padding_vertical"
                android:background="@color/bg_mid"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_field"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    android:hint="@string/hint_search_conversation"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="@dimen/text_body"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/btn_cancel"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/primary"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/btn_cancel" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSearchResultCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_page"
                android:paddingVertical="@dimen/spacing_sm"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvArchiveHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_page"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="@string/hint_archive_older_messages"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/bg_archive_hint"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/layoutChatEmpty"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone">

                <include layout="@layout/layout_app_empty_state" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMessages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="@dimen/message_list_padding"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/input_padding"
                android:background="@drawable/bg_glass_bottom">

                <EditText
                    android:id="@+id/etInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:maxHeight="120dp"
                    android:padding="@dimen/input_padding"
                    android:maxLines="5"
                    android:hint="@string/hint_input_message"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:background="@drawable/bg_input_field_selector"
                    android:inputType="textMultiLine"
                    android:imeOptions="actionSend" />

                <ImageButton
                    android:id="@+id/btnVoice"
                    android:layout_width="@dimen/button_small"
                    android:layout_height="@dimen/button_small"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:src="@drawable/ic_mic"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_voice_input"
                    android:tint="@color/sakura_border"
                    android:scaleType="centerInside"
                    android:padding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSend"
                    style="@style/AppButton.Primary"
                    android:layout_width="@dimen/button_small"
                    android:layout_height="@dimen/button_small"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/btn_send"
                    android:textSize="@dimen/text_title"
                    android:enabled="false"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:stateListAnimator="@null"
                    android:contentDescription="@string/btn_send" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnScrollBottom"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_arrow_down"
            android:contentDescription="@string/cd_scroll_to_bottom"
            android:visibility="gone"
            android:elevation="4dp"
            app:fabSize="mini"
            app:backgroundTint="@color/primary"
            app:tint="@color/text_primary"
            android:scaleType="center" />

        <FrameLayout
            android:id="@+id/splashOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_main_gradient"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/splashProgress"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary" />

                <TextView
                    android:id="@+id/tvSplashTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tvSplashStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_initializing"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body_small"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- ===== 会话抽屉（左侧滑出） ===== -->
    <LinearLayout
        android:id="@+id/drawerSessionList"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card">

        <!-- 抽屉头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_page"
            android:background="@drawable/bg_glass_top">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drawer_session_list_title"
                android:textSize="@dimen/text_title_small"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/btnDrawerNewChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/drawer_new_chat"
                android:textSize="@dimen/text_body"
                android:textColor="@color/primary"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/btn_new_chat" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- 会话列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSessionList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- 抽屉底部操作 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_page">

            <TextView
                android:id="@+id/btnDrawerExport"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drawer_export_records"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btnDrawerSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drawer_search"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
