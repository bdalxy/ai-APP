<?xml version="1.0" encoding="utf-8"?>
<!-- 聊天主页面布局：玻璃态顶栏 + 消息列表 + 毛玻璃输入区 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- 背景粒子层 -->
    <com.aicompanion.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.5" />

    <!-- 主内容区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 玻璃态顶栏 -->
        <LinearLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:background="@color/glass_bg"
            android:elevation="8dp"
            android:outlineSpotShadowColor="@color/glow_purple">

            <!-- 头像 -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_avatar_border"
                android:scaleType="centerCrop"
                android:contentDescription="角色头像" />

            <!-- 名称 + 状态 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小美"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_online" />
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="在线"
                        android:textSize="11sp"
                        android:textColor="@color/accent_green"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 菜单按钮 -->
            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="≡"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="设置菜单" />
        </LinearLayout>

        <!-- 消息列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingVertical="8dp"
            android:clipToPadding="false"
            android:background="@android:color/transparent" />

        <!-- 输入区域（玻璃态） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:background="@color/glass_bg"
            android:elevation="8dp">

            <!-- 插件按钮 -->
            <TextView
                android:id="@+id/btnPlugins"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="22sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="插件面板" />

            <!-- 输入框 -->
            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="输入消息..."
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:maxLines="3"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textSize="15sp"
                android:background="@drawable/bg_input_field"
                android:inputType="textMultiLine"
                android:imeOptions="actionSend"
                android:layout_marginHorizontal="6dp" />

            <!-- 发送按钮 -->
            <TextView
                android:id="@+id/btnSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="→"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_btn_send_disabled"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:contentDescription="发送消息" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>