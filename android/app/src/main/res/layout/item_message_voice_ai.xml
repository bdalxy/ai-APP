<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp">
    <LinearLayout
        android:id="@+id/layoutMessageRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_gravity="start">
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar_placeholder"
            android:contentDescription="@string/cd_ai_avatar" />
        <ImageView
            android:id="@+id/ivPlayPause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_play_button"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_play_voice" />
        <LinearLayout
            android:id="@+id/layoutVoiceBubble"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_bubble_ai"
            android:minWidth="80dp"
            android:layout_marginEnd="6dp">
            <ImageView
                android:id="@+id/ivWaveform"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_voice_wave"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/bubble_ai_text"
                android:layout_marginStart="6dp"
                tools:text="0:15" />
        </LinearLayout>
        <View
            android:id="@+id/vUnreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/bg_unread_dot"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
