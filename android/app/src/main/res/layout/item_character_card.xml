<?xml version="1.0" encoding="utf-8"?>
<!-- 角色卡片列表项：头像 + 名称简介 + 当前指示 + 编辑/删除 -->
<com.aicompanion.app.ui.GlassCard
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_page"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/glass_bg"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/card_padding"
        android:paddingVertical="@dimen/card_list_padding_vertical_item"
        android:background="?attr/selectableItemBackground">

        <!-- 左侧：圆形头像边框占位 -->
        <ImageView
            android:id="@+id/ivCharacterAvatar"
            android:layout_width="@dimen/avatar_size_medium"
            android:layout_height="@dimen/avatar_size_medium"
            android:background="@drawable/bg_avatar_border"
            android:scaleType="centerCrop"
            android:contentDescription="@string/cd_avatar" />

        <!-- 中间：名称 + 简介预览 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_xl"
            android:layout_marginEnd="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvCharacterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCharacterPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="@dimen/spacing_xxs" />
        </LinearLayout>

        <!-- 右侧：当前指示绿点 + 编辑 + 删除 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 当前选中指示绿点 -->
            <View
                android:id="@+id/ivCurrentDot"
                android:layout_width="@dimen/spacing_md"
                android:layout_height="@dimen/spacing_md"
                android:background="@drawable/bg_status_online"
                android:visibility="gone"
                android:layout_marginEnd="@dimen/spacing_md" />

            <!-- 编辑按钮 -->
            <TextView
                android:id="@+id/btnEditCharacter"
                android:layout_width="@dimen/avatar_size_small"
                android:layout_height="@dimen/avatar_size_small"
                android:text="@string/btn_edit"
                android:textSize="@dimen/text_title"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_edit_character"
                android:background="?attr/selectableItemBackground"
                android:layout_marginEnd="@dimen/spacing_xs" />

            <!-- 删除按钮 -->
            <TextView
                android:id="@+id/btnDeleteCharacter"
                android:layout_width="@dimen/avatar_size_small"
                android:layout_height="@dimen/avatar_size_small"
                android:text="@string/btn_clear"
                android:textSize="@dimen/text_subtitle"
                android:textColor="@color/accent_red"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_delete_character"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>
</com.aicompanion.app.ui.GlassCard>