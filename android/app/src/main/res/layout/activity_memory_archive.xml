<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/archiveRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height_alt"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_page"
            android:background="@drawable/bg_glass_top"
            android:elevation="@dimen/topbar_elevation">
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/button_medium"
                android:layout_height="@dimen/button_medium"
                android:text="@string/btn_back_arrow"
                android:textSize="@dimen/text_large"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/cd_back" />
            <TextView
                android:id="@+id/tvArchiveTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_memory_archive"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />
            <View
                android:layout_width="@dimen/button_medium"
                android:layout_height="@dimen/button_medium" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_memory_archive"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:alpha="0.8" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvArchive"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="80dp"
            android:scrollbars="none" />
        <FrameLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">
            <include layout="@layout/layout_app_empty_state" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">
            <include layout="@layout/layout_app_loading_state" />
        </FrameLayout>
    </LinearLayout>

    <!-- 删除确认面板 -->
    <LinearLayout
        android:id="@+id/layoutDeleteConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_md"
        android:background="@drawable/bg_glass_bottom"
        android:visibility="gone"
        android:elevation="8dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelDelete"
            style="@style/AppButton.Secondary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_wide"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/btn_cancel"
            android:textSize="@dimen/text_body" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmDelete"
            style="@style/AppButton.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_wide"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/btn_delete"
            android:textSize="@dimen/text_body"
            app:backgroundTint="@color/accent_red" />
    </LinearLayout>
</FrameLayout>
