<?xml version="1.0" encoding="utf-8"?>
<!-- 角色列表页：顶栏 + 角色卡片 RecyclerView -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/character_manage_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- ===== 玻璃态顶栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:background="@color/glass_bg"
        android:elevation="@dimen/topbar_elevation">

        <!-- 返回按钮 -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/button_small"
            android:layout_height="@dimen/button_small"
            android:text="@string/btn_back_arrow"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back" />

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_character_manage"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <!-- 新建按钮 -->
        <TextView
            android:id="@+id/btnNewCharacter"
            android:layout_width="@dimen/tag_width_wide"
            android:layout_height="@dimen/tag_height"
            android:text="@string/btn_new_character"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_new_character" />
    </LinearLayout>

    <!-- ===== 角色卡片列表 ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCharacters"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingVertical="@dimen/card_list_padding_vertical"
        android:clipToPadding="false" />
</LinearLayout>