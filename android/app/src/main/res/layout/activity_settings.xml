<?xml version="1.0" encoding="utf-8"?>
<!-- 设置页面：淡樱粉渐变标题栏 + 分组 GlassCard 卡片 -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_page">

        <!-- ===== 淡樱粉渐变标题栏 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height_alt"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_sakura_header"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:elevation="2dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/button_medium"
                android:layout_height="@dimen/button_medium"
                android:text="@string/btn_back_arrow"
                android:textSize="@dimen/text_large"
                android:textColor="@color/wb_text_warm"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/cd_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_settings"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:textColor="@color/wb_text_warm"
                android:gravity="center" />

            <View
                android:layout_width="@dimen/button_medium"
                android:layout_height="@dimen/button_medium" />
        </LinearLayout>

        <!-- ===== 一、账号设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardAccount"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_account"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_account_settings" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_account_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAccountSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 二、对话设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardChat"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_chat"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_chat_settings" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_chat_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvChatSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 三、记忆设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardMemory"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_memory"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_memory_manage" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_memory_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMemorySummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 四、语音设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardVoice"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_voice"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_voice_settings" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_voice_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVoiceSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 显示设置卡片（主题切换） ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardDisplay"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_display"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_display" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_display"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDisplaySummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="浅色模式"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/cd_dark_mode" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 语言设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardLanguage"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_display"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/section_language" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_language"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLanguageSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="中文"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 六、通知设置卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardNotification"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_notification"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_proactive_messages" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_notification_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNotificationSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 六、关于卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardAbout"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_export"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_about_settings" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_about_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_version"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 世界书卡片（快捷入口） ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardWorldBook"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_world"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_world_book" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_world_book"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWorldBookSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 插件管理卡片（快捷入口） ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardPlugin"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_plugin"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/cd_plugin_manage" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_plugin_manage"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPluginSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_loading_ellipsis"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 导出对话卡片（快捷入口） ===== -->
        <com.aicompanion.app.ui.GlassCard
            android:id="@+id/cardExport"
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_export"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/label_export_chat" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_export_chat"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_export_chat"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:text="@string/icon_chevron"
                    android:textSize="@dimen/text_heading"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_spacer"
            android:importantForAccessibility="no" />

    </LinearLayout>
</ScrollView>