<?xml version="1.0" encoding="utf-8"?>
<!-- 记忆管理页面布局 — UI v0.1.0 统一改造 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/memory_manage_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height_alt"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_page"
        android:background="@drawable/bg_glass_top"
        android:elevation="@dimen/topbar_elevation">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/button_medium"
            android:layout_height="@dimen/button_medium"
            android:text="@string/btn_back_arrow"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_memory_manage"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <TextView
            android:id="@+id/btnRefresh"
            android:layout_width="@dimen/button_medium"
            android:layout_height="@dimen/button_medium"
            android:text="@string/btn_refresh"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/btn_refresh" />
    </LinearLayout>

    <!-- 统计信息栏 -->
    <com.aicompanion.app.ui.GlassCard
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_page"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:contentPadding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_body_small"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvMemoryDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_memory_ai_perspective"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/tvStatsLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_loading"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_tertiary"
                android:visibility="gone" />
        </LinearLayout>
    </com.aicompanion.app.ui.GlassCard>

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height_alt"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_md">

        <EditText
            android:id="@+id/etSearch"
            style="@style/AppInput.Search"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:hint="@string/hint_search_memories"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <TextView
            android:id="@+id/btnClearSearch"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/btn_clear"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:layout_marginStart="@dimen/spacing_md"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 分类过滤栏 -->
    <HorizontalScrollView
        android:id="@+id/hsvFilterChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="4dp">

        <LinearLayout
            android:id="@+id/layoutFilterChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_page" />
    </HorizontalScrollView>

    <!-- 记忆列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMemories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs" />

    <!-- 空状态提示 -->
    <FrameLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <include layout="@layout/layout_app_empty_state" />
    </FrameLayout>

    <!-- 加载状态提示 -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <include layout="@layout/layout_app_loading_state" />
    </FrameLayout>

    <!-- 加载更多提示 -->
    <TextView
        android:id="@+id/tvLoadMore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_load_more"
        android:textSize="@dimen/text_caption"
        android:textColor="@color/text_tertiary"
        android:gravity="center"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone" />

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_md"
        android:background="@drawable/bg_glass_bottom">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAll"
            style="@style/AppButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_wide"
            android:text="@string/action_clear_all_memories"
            android:textSize="@dimen/text_body"
            app:backgroundTint="@color/accent_red" />
    </LinearLayout>

</LinearLayout>