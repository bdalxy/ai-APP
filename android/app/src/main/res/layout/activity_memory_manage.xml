<?xml version="1.0" encoding="utf-8"?>
<!-- 记忆管理页面布局 -->
<!-- 优化：增大按钮和搜索栏可点击区域，适配 HyperOS/MagicOS 缩放 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/memory_manage_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height_alt"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:background="?attr/colorPrimary"
        android:elevation="@dimen/topbar_elevation">

        <!-- 返回按钮 -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_medium"
            android:text="@string/btn_back_arrow_label"
            android:textSize="@dimen/text_body_small"
            android:minWidth="0dp"
            android:paddingHorizontal="@dimen/spacing_xl"
            android:backgroundTint="?attr/colorOnPrimary"
            android:textColor="?attr/colorPrimary" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_memory_manage"
            android:textSize="@dimen/text_title_small"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:gravity="center" />

        <!-- 刷新按钮 -->
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="@dimen/button_medium"
            android:layout_height="@dimen/button_medium"
            android:text="@string/btn_refresh"
            android:textSize="@dimen/text_title"
            android:minWidth="0dp"
            android:padding="0dp"
            android:backgroundTint="?attr/colorOnPrimary"
            android:textColor="?attr/colorPrimary" />
    </LinearLayout>

    <!-- 统计信息栏 -->
    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_xl"
        android:background="?attr/colorSurfaceVariant"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/stats_total_memories"
            android:textSize="@dimen/text_body_small"
            android:textColor="?attr/colorOnSurface" />

        <!-- 加载中指示 -->
        <TextView
            android:id="@+id/tvStatsLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_loading"
            android:textSize="@dimen/text_small"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height_alt"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingVertical="@dimen/spacing_md"
        android:background="?attr/colorSurface">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/hint_search_memories"
            android:textSize="@dimen/text_body_small"
            android:paddingHorizontal="@dimen/search_padding_horizontal"
            android:paddingVertical="@dimen/search_padding_vertical"
            android:background="@android:drawable/edit_text"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <!-- 清除搜索按钮 -->
        <Button
            android:id="@+id/btnClearSearch"
            android:layout_width="@dimen/button_small"
            android:layout_height="@dimen/button_small"
            android:text="@string/btn_clear"
            android:textSize="@dimen/text_body_small"
            android:minWidth="0dp"
            android:padding="0dp"
            android:layout_marginStart="@dimen/spacing_md"
            android:backgroundTint="?attr/colorSurfaceVariant"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 记忆列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMemories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/empty_memories"
        android:textSize="@dimen/text_body"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:lineSpacingExtra="@dimen/spacing_sm"
        android:visibility="gone" />

    <!-- 加载更多提示 -->
    <TextView
        android:id="@+id/tvLoadMore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_load_more"
        android:textSize="@dimen/text_caption"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:paddingVertical="@dimen/spacing_md"
        android:visibility="gone" />

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="@dimen/spacing_page"
        android:background="?attr/colorSurfaceVariant">

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_wide"
            android:text="@string/action_clear_all_memories"
            android:textSize="@dimen/text_body"
            android:textColor="@color/onPrimary"
            android:backgroundTint="@color/accent_red" />
    </LinearLayout>

</LinearLayout>