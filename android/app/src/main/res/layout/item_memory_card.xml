<?xml version="1.0" encoding="utf-8"?>
<!-- 记忆档案馆卡片布局 — 瀑布流风格 -->
<!-- 天使白半透明卡片，圆角16dp，边缘淡天蓝渐变高光 -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardBackgroundColor="#E6FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="#1AB0C4DE"
    app:strokeWidth="1dp"
    android:clipToOutline="true"
    android:clickable="true"
    android:focusable="true">

    <!-- 卡片内容容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 日期标签 -->
        <TextView
            android:id="@+id/tvDateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6月15日"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:alpha="0.7"
            android:fontFamily="sans-serif-light" />

        <!-- 诗意摘要（3行） -->
        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今天的阳光很温暖，\n你和我一起走过了那条\n开满樱花的小路..."
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="10dp"
            android:minLines="2"
            android:maxLines="3"
            android:ellipsize="end"
            android:fontFamily="sans-serif" />

        <!-- 情感标签容器 -->
        <LinearLayout
            android:id="@+id/layoutTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="回忆"
                android:textSize="10sp"
                android:textColor="@color/elysian_purple"
                android:background="@drawable/bg_type_label"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="温暖"
                android:textSize="10sp"
                android:textColor="@color/elysian_purple"
                android:background="@drawable/bg_type_label"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTag3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快乐"
                android:textSize="10sp"
                android:textColor="@color/elysian_purple"
                android:background="@drawable/bg_type_label"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>