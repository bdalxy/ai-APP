<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/preview_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:background="@color/glass_bg"
        android:elevation="@dimen/topbar_elevation">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/button_small"
            android:layout_height="@dimen/button_small"
            android:text="@string/btn_back_arrow"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_character_preview"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />
        <View
            android:layout_width="@dimen/button_small"
            android:layout_height="@dimen/button_small" />
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_page">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <FrameLayout
                android:layout_width="@dimen/avatar_size_xlarge"
                android:layout_height="@dimen/avatar_size_xlarge"
                android:layout_marginTop="@dimen/spacing_3xl"
                android:layout_marginBottom="@dimen/spacing_xl">
                <View
                    android:layout_width="@dimen/avatar_inner_large"
                    android:layout_height="@dimen/avatar_inner_large"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_border" />
                <ImageView
                    android:id="@+id/ivPreviewAvatar"
                    android:layout_width="@dimen/avatar_size_large"
                    android:layout_height="@dimen/avatar_size_large"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/cd_avatar" />
            </FrameLayout>
            <TextView
                android:id="@+id/tvPreviewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xlarge"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_xs" />
            <TextView
                android:id="@+id/tvPreviewPersonality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_body_small"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_3xl"
                android:paddingHorizontal="@dimen/spacing_5xl" />
            <com.aicompanion.app.ui.GlassCard
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_3xl"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:contentPadding="@dimen/card_padding">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_greeting_preview"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginBottom="@dimen/spacing_md" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start">
                        <View
                            android:layout_width="@dimen/avatar_size_small"
                            android:layout_height="@dimen/avatar_size_small"
                            android:background="@drawable/bg_avatar_border"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:layout_marginTop="@dimen/spacing_xs" />
                        <TextView
                            android:id="@+id/tvPreviewGreeting"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/bubble_ai_text"
                            android:background="@drawable/bg_bubble_ai"
                            android:paddingHorizontal="@dimen/message_bubble_padding_h"
                            android:paddingVertical="@dimen/message_bubble_padding_v"
                            android:lineSpacingExtra="@dimen/spacing_xs" />
                    </LinearLayout>
                </LinearLayout>
            </com.aicompanion.app.ui.GlassCard>
            <com.aicompanion.app.ui.GlassCard
                android:id="@+id/cardDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_3xl"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:contentPadding="@dimen/card_padding">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_personality"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />
                    <TextView
                        android:id="@+id/tvDetailPersonality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="@dimen/spacing_xs"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvDetailBackstory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="@dimen/spacing_xs"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/spacing_md" />
                </LinearLayout>
            </com.aicompanion.app.ui.GlassCard>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_spacer_large" />
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_md"
        android:background="@drawable/bg_glass_bottom"
        android:elevation="4dp">
        <TextView
            android:id="@+id/btnBackEdit"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_default"
            android:layout_weight="1"
            android:text="@string/btn_back_edit"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="@dimen/spacing_md" />
        <TextView
            android:id="@+id/btnConfirmCreate"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_default"
            android:layout_weight="1"
            android:text="@string/btn_confirm_create"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/bubble_user_text"
            android:gravity="center"
            android:background="@drawable/bg_btn_send"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
