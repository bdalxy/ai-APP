<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/character_edit_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:background="@color/glass_bg"
        android:elevation="@dimen/topbar_elevation">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/button_small"
            android:layout_height="@dimen/button_small"
            android:text="@string/btn_back_arrow"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back" />
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_create_character"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />
        <TextView
            android:id="@+id/btnSave"
            android:layout_width="@dimen/tag_width_narrow"
            android:layout_height="@dimen/tag_height"
            android:text="@string/btn_save"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/bubble_user_text"
            android:gravity="center"
            android:background="@drawable/bg_btn_send"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_save_character"
            android:visibility="gone" />
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_page">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <com.aicompanion.app.ui.GlassCard
                android:id="@+id/cardModeSelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:visibility="visible"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:contentPadding="@dimen/card_padding">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dialog_create_mode_title"
                        android:textSize="@dimen/text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_md" />
                    <LinearLayout
                        android:id="@+id/optionBasic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:background="@drawable/bg_input_field"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="@dimen/spacing_sm">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dialog_create_mode_basic"
                                android:textSize="@dimen/text_body_small"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dialog_create_mode_basic_desc"
                                android:textSize="@dimen/text_small"
                                android:textColor="@color/text_tertiary"
                                android:layout_marginTop="@dimen/spacing_xxs" />
                        </LinearLayout>
                        <View
                            android:id="@+id/dotBasic"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_status_online" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/optionPro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:background="@drawable/bg_input_field"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dialog_create_mode_pro"
                                android:textSize="@dimen/text_body_small"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dialog_create_mode_pro_desc"
                                android:textSize="@dimen/text_small"
                                android:textColor="@color/text_tertiary"
                                android:layout_marginTop="@dimen/spacing_xxs" />
                        </LinearLayout>
                        <View
                            android:id="@+id/dotPro"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_input_field"
                            android:visibility="invisible" />
                    </LinearLayout>
                </LinearLayout>
            </com.aicompanion.app.ui.GlassCard>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_character_name"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginStart="@dimen/spacing_xs" />
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_character_name"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:paddingHorizontal="@dimen/input_padding_horizontal"
                android:paddingVertical="@dimen/input_padding_vertical"
                android:background="@drawable/bg_input_field"
                android:maxLines="1"
                android:inputType="text"
                android:importantForAutofill="no"
                android:layout_marginBottom="@dimen/spacing_xs" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_character_name_sub"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_tertiary"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_page" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_personality"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginStart="@dimen/spacing_xs" />
            <EditText
                android:id="@+id/etPersonality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_personality"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:paddingHorizontal="@dimen/input_padding_horizontal"
                android:paddingVertical="@dimen/input_padding_vertical"
                android:background="@drawable/bg_input_field"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="@dimen/spacing_xs" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_personality_sub"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_tertiary"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_page" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_greeting"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginStart="@dimen/spacing_xs" />
            <EditText
                android:id="@+id/etGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_greeting"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:paddingHorizontal="@dimen/input_padding_horizontal"
                android:paddingVertical="@dimen/input_padding_vertical"
                android:background="@drawable/bg_input_field"
                android:maxLines="2"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="@dimen/spacing_xs" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_greeting_sub"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_tertiary"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_page" />
            <TextView
                android:id="@+id/tvProSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_pro_fields"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_page"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />
            <LinearLayout
                android:id="@+id/proFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_speaking_style"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="@dimen/spacing_xs" />
                <EditText
                    android:id="@+id/etSpeakingStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_speaking_style"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:paddingHorizontal="@dimen/input_padding_horizontal"
                    android:paddingVertical="@dimen/input_padding_vertical"
                    android:background="@drawable/bg_input_field"
                    android:minLines="3"
                    android:maxLines="6"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="@dimen/spacing_xs" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_speaking_style_sub"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_page" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_backstory"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="@dimen/spacing_xs" />
                <EditText
                    android:id="@+id/etBackstory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_backstory"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:paddingHorizontal="@dimen/input_padding_horizontal"
                    android:paddingVertical="@dimen/input_padding_vertical"
                    android:background="@drawable/bg_input_field"
                    android:minLines="3"
                    android:maxLines="8"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="@dimen/spacing_xs" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_backstory_sub"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_page" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_core_traits"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="@dimen/spacing_xs" />
                <EditText
                    android:id="@+id/etCoreTraits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_core_traits"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:paddingHorizontal="@dimen/input_padding_horizontal"
                    android:paddingVertical="@dimen/input_padding_vertical"
                    android:background="@drawable/bg_input_field"
                    android:maxLines="2"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="@dimen/spacing_xs" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_core_traits_sub"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_page" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_taboo_topics"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="@dimen/spacing_xs" />
                <EditText
                    android:id="@+id/etTabooTopics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_taboo_topics"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:paddingHorizontal="@dimen/input_padding_horizontal"
                    android:paddingVertical="@dimen/input_padding_vertical"
                    android:background="@drawable/bg_input_field"
                    android:maxLines="2"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="@dimen/spacing_xs" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_taboo_topics_sub"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_page" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_role_anchor"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="@dimen/spacing_xs" />
                <EditText
                    android:id="@+id/etRoleAnchor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_role_anchor"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:paddingHorizontal="@dimen/input_padding_horizontal"
                    android:paddingVertical="@dimen/input_padding_vertical"
                    android:background="@drawable/bg_input_field"
                    android:minLines="2"
                    android:maxLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"
                    android:layout_marginBottom="@dimen/spacing_xs" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_role_anchor_sub"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_page" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_spacer_large" />
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_page"
        android:paddingVertical="@dimen/spacing_md"
        android:background="@drawable/bg_glass_bottom"
        android:gravity="center"
        android:elevation="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/btnPreview"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_default"
            android:layout_weight="1"
            android:text="@string/btn_preview"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/bubble_user_text"
            android:gravity="center"
            android:background="@drawable/bg_btn_send"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
