<?xml version="1.0" encoding="utf-8"?>
<!-- 创建/编辑角色页：顶栏 + 表单滚动区 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- ===== 玻璃态顶栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:background="@color/glass_bg"
        android:elevation="4dp">

        <!-- 返回按钮 -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="返回" />

        <!-- 页面标题 -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="创建角色"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <!-- 保存按钮（粉紫渐变） -->
        <TextView
            android:id="@+id/btnSave"
            android:layout_width="56dp"
            android:layout_height="34dp"
            android:text="保存"
            android:textSize="13sp"
            android:textColor="@color/bubble_user_text"
            android:gravity="center"
            android:background="@drawable/bg_btn_send"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="保存角色" />
    </LinearLayout>

    <!-- ===== 表单滚动区 ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 角色名称 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="角色名称"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="给角色起个名字"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/bg_input_field"
                android:maxLines="1"
                android:inputType="text"
                android:importantForAutofill="no"
                android:layout_marginBottom="16dp" />

            <!-- 性格特征 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="性格特征"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/etPersonality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="描述角色的性格特点，如：温柔、活泼、善解人意"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/bg_input_field"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="16dp" />

            <!-- 说话风格 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="说话风格"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/etSpeakingStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="描述角色的说话方式，如语气、常用词、语速等"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/bg_input_field"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="16dp" />

            <!-- 背景故事 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="背景故事"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/etBackstory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="角色的出身、经历和世界观设定"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/bg_input_field"
                android:minLines="3"
                android:maxLines="8"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="16dp" />

            <!-- 开场白 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开场白"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <EditText
                android:id="@+id/etGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="角色见到用户时说的第一句话"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:background="@drawable/bg_input_field"
                android:maxLines="2"
                android:inputType="textMultiLine"
                android:importantForAutofill="no"
                android:layout_marginBottom="24dp" />

            <!-- 底部留白，防止被导航栏遮挡 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
