<?xml version="1.0" encoding="utf-8"?>
<!-- 角色卡页面：头像 + 名称 + 描述 + 特征卡片 + 角色切换列表 -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_page"
        android:gravity="center_horizontal">

        <!-- ===== 顶栏 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_default"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/button_small"
                android:layout_height="@dimen/button_small"
                android:text="@string/btn_back_arrow"
                android:textSize="@dimen/text_large"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_character_card"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <View
                android:layout_width="@dimen/button_small"
                android:layout_height="@dimen/button_small" />
        </LinearLayout>

        <!-- ===== 角色头像 ===== -->
        <FrameLayout
            android:layout_width="@dimen/avatar_size_xlarge"
            android:layout_height="@dimen/avatar_size_xlarge"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_page">

            <View
                android:layout_width="@dimen/avatar_inner_large"
                android:layout_height="@dimen/avatar_inner_large"
                android:layout_gravity="center"
                android:background="@drawable/bg_avatar_border" />

            <ImageView
                android:id="@+id/ivCharacterAvatar"
                android:layout_width="@dimen/avatar_size_large"
                android:layout_height="@dimen/avatar_size_large"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:contentDescription="@string/cd_avatar" />
        </FrameLayout>

        <!-- 角色名称 -->
        <TextView
            android:id="@+id/tvCharacterName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_default_character_name"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <!-- 角色描述 -->
        <TextView
            android:id="@+id/tvCharacterDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/default_character_desc"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_3xl" />

        <!-- ===== 性格特征卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            app:contentPadding="@dimen/card_padding_small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SettingsItemTitle"
                    android:text="@string/label_personality"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvPersonality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/default_personality"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="@dimen/spacing_xs" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 说话风格卡片 ===== -->
        <com.aicompanion.app.ui.GlassCard
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_3xl"
            app:contentPadding="@dimen/card_padding_small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SettingsItemTitle"
                    android:text="@string/label_speaking_style"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvSpeakingStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/default_speaking_style"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="@dimen/spacing_xs" />
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 角色切换列表 ===== -->
        <com.aicompanion.app.ui.GlassCard
            style="@style/GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            app:contentPadding="@dimen/card_padding_min">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SettingsItemTitle"
                    android:text="@string/label_character_switch"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <RadioGroup
                    android:id="@+id/rgCharacter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbCharacter1"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/radio_item_height"
                        android:text="@string/character_option_1"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_small"
                        android:checked="true"
                        android:buttonTint="@color/elysian_purple" />

                    <RadioButton
                        android:id="@+id/rbCharacter2"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/radio_item_height"
                        android:text="@string/character_option_2"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_small"
                        android:buttonTint="@color/elysian_purple" />

                    <RadioButton
                        android:id="@+id/rbCharacter3"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/radio_item_height"
                        android:text="@string/character_option_3"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_small"
                        android:buttonTint="@color/elysian_purple" />
                </RadioGroup>
            </LinearLayout>
        </com.aicompanion.app.ui.GlassCard>

        <!-- ===== 自定义角色卡入口 ===== -->
        <TextView
            android:id="@+id/btnCustomCharacter"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_default"
            android:text="@string/btn_custom_character_coming"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/text_tertiary"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>