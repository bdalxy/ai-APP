<?xml version="1.0" encoding="utf-8"?>
<!-- 聊天消息气泡布局：支持文字气泡 + 打字指示器 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/layoutMessageRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <!-- 文字气泡 -->
        <TextView
            android:id="@+id/tvContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:lineSpacingExtra="4dp"
            android:elevation="2dp"
            android:outlineSpotShadowColor="@color/glow_pink"
            android:maxWidth="280dp" />

        <!-- 打字指示器 -->
        <LinearLayout
            android:id="@+id/layoutTyping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_bubble_typing"
            android:visibility="gone">

            <View
                android:id="@+id/dot1"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_typing_dot" />
            <View
                android:id="@+id/dot2"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_typing_dot" />
            <View
                android:id="@+id/dot3"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_typing_dot" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>