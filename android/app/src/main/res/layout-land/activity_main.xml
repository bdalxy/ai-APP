<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:clipToPadding="false">
    <com.aicompanion.app.ui.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height_land"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_page"
            android:background="@drawable/bg_glass_top">
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="@dimen/avatar_size_small"
                android:layout_height="@dimen/avatar_size_small"
                android:src="@drawable/ic_avatar_placeholder"
                android:contentDescription="@string/cd_avatar" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg">
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tv_default_character_name"
                    android:textSize="@dimen/text_title_small"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_online"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/accent_green" />
            </LinearLayout>
            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="@dimen/icon_size_small"
                android:layout_height="@dimen/icon_size_small"
                android:src="@drawable/ic_search"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_search"
                android:tint="@color/text_primary" />
            <TextView
                android:id="@+id/btnNewChat"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/avatar_size_small"
                android:text="@string/btn_new_chat"
                android:textSize="@dimen/text_small"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/btn_new_chat" />
            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="@dimen/avatar_size_small"
                android:layout_height="@dimen/avatar_size_small"
                android:text="@string/btn_menu"
                android:textSize="@dimen/text_xlarge"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/cd_settings" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/layoutSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_page"
            android:paddingVertical="@dimen/search_padding_vertical"
            android:background="@color/bg_mid"
            android:visibility="gone">
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_search_field"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/hint_search_conversation"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="@dimen/text_body"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:maxLines="1" />
            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:text="取消"
                android:textSize="@dimen/text_body"
                android:textColor="@color/primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/btn_cancel" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvSearchResultCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_page"
            android:paddingVertical="@dimen/spacing_sm"
            android:textSize="@dimen/text_small"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:visibility="gone" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="@dimen/message_list_padding_land"
            android:clipToPadding="false"
            android:overScrollMode="never" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/input_padding"
            android:background="@drawable/bg_glass_bottom">
            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:maxHeight="120dp"
                android:padding="@dimen/input_padding"
                android:maxLines="3"
                android:hint="@string/hint_input_message"
                android:textColorHint="@color/text_tertiary"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:background="@drawable/bg_input_field_selector"
                android:inputType="textMultiLine"
                android:imeOptions="actionSend" />
            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="@dimen/button_small"
                android:layout_height="@dimen/button_small"
                android:layout_marginStart="@dimen/spacing_md"
                android:src="@drawable/ic_mic"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_voice_input"
                android:tint="@color/sakura_border"
                android:scaleType="centerInside"
                android:padding="6dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSend"
                style="@style/AppButton.Primary"
                android:layout_width="@dimen/button_small"
                android:layout_height="@dimen/button_small"
                android:layout_marginStart="@dimen/spacing_md"
                android:text="@string/btn_send"
                android:textSize="@dimen/text_title"
                android:enabled="false"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:stateListAnimator="@null"
                android:contentDescription="@string/btn_send" />
        </LinearLayout>
    </LinearLayout>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnScrollBottom"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/ic_arrow_down"
        android:contentDescription="滚动到底部"
        android:visibility="gone"
        android:elevation="4dp"
        app:fabSize="mini"
        app:backgroundTint="@color/primary"
        app:tint="@color/text_primary"
        android:scaleType="center" />
</FrameLayout>
