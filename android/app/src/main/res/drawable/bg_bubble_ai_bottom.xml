<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sakura_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sakura_white" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/sakura_border" />
        </shape>
    </item>
</layer-list>