<?xml version="1.0" encoding="utf-8"?>
<!-- AI 消息气泡组中：上下衔接圆角（四角平直），淡天蓝描边，天使白填充 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="2dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sakura_shadow" />
            <corners android:radius="0dp" />
        </shape>
    </item>
    <!-- 主体 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bubble_ai" />
            <corners android:radius="0dp" />
            <stroke
                android:width="1dp"
                android:color="@color/sakura_border" />
        </shape>
    </item>
</layer-list>
