<?xml version="1.0" encoding="utf-8"?>
<!-- 用户消息气泡组中：四角 4dp 小圆角衔接，淡樱粉渐变 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="2dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sakura_shadow" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <!-- 主体渐变 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/sakura_gradient_start"
                android:endColor="@color/sakura_gradient_end"
                android:type="linear" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
