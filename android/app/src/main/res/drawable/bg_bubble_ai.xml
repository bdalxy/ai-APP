<?xml version="1.0" encoding="utf-8"?>
<!-- AI 消息气泡：粉色柔光，圆角+边框+阴影 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bubble_ai_shadow" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- 主体 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bubble_ai" />
            <corners android:radius="20dp" />
            <stroke
                android:width="0.5dp"
                android:color="@color/bubble_ai_stroke" />
        </shape>
    </item>
</layer-list>