# ============================================
# WeiXinAI - AI 角色扮演聊天 APP 环境配置模板
# ============================================
# 使用说明：复制此文件为 .env 并填入实际配置
# 敏感信息（如 API Key）切勿提交到 GitHub！
# ============================================

# ------------------------------
# 基础配置（必填）
# ------------------------------

# AI 运行模式
# cloud: 使用云端 API（推荐）
# local: 使用本地模型
AI_MODE=cloud

# 消息平台
# wechat: 微信
# qq: QQ
# local: 本地聊天
PLATFORM=wechat

# ------------------------------
# 云端 API 配置（AI_MODE=cloud 时必填）
# ------------------------------

# DeepSeek API Key
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址 (OpenAI 兼容)
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# DeepSeek Embedding API 地址
DEEPSEEK_EMBEDDING_URL=https://api.deepseek.com/v1/embeddings

# 模型名称
# deepseek-v4-flash: 推荐默认, ￥1/百万tokens输入, ￥2/百万tokens输出
# deepseek-v4-pro: 旗舰模型, ￥3/百万tokens输入, ￥6/百万tokens输出
# deepseek-r1: 推理模型, 用于复杂推理任务
MODEL_NAME=deepseek-v4-flash

# Embedding 模型
# deepseek-embedding-v2: 768维向量
EMBEDDING_MODEL=deepseek-embedding-v2

# ------------------------------
# 本地模型配置（AI_MODE=local 时必填）
# ------------------------------

# 本地模型路径
LOCAL_MODEL_PATH=./models/your_model.gguf

# ------------------------------
# 记忆系统配置
# ------------------------------

# 记忆级别
# basic: 基础（100条记录）
# standard: 标准（500条记录）
# advanced: 高级（无限制）
MEMORY_LEVEL=standard

# ------------------------------
# 联网搜索配置（可选）
# ------------------------------

# 搜索提供商
# duckduckgo: 使用 DuckDuckGo（无需 API Key，推荐）
# bing: 使用 Bing Search API
SEARCH_PROVIDER=duckduckgo

# Bing Search API Key（使用 Bing 时必填）
SEARCH_API_KEY=your_bing_api_key_here

# ------------------------------
# 日志配置
# ------------------------------

# 日志级别
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------
# API 服务配置（仅桌面调试模式）
# ------------------------------

# 服务端口
API_PORT=8000

# 服务地址
API_HOST=127.0.0.1

# ------------------------------
# DeepSeek API 最新定价参考 (2026年6月)
# 详见: https://api-docs.deepseek.com/zh-cn/quick_start/pricing/
# ------------------------------
# 模型              | 缓存命中输入 | 缓存未命中输入 | 输出
# deepseek-v4-flash | ￥0.02/百万   | ￥1/百万       | ￥2/百万
# deepseek-v4-pro   | ￥0.025/百万  | ￥3/百万       | ￥6/百万
# deepseek-r1       | $0.14/百万    | $0.55/百万     | $2.19/百万
# ------------------------------
# 注意: deepseek-chat 和 deepseek-reasoner 将于 2026/07/24 弃用
# 请使用 deepseek-v4-flash 替代
# ------------------------------